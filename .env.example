# CloudOS — Environment Configuration
# Copy to .env and adjust for your environment

# Logging
CLOUDOS_LOG_LEVEL=debug

# API Server
CLOUDOS_PORT=8080
CLOUDOS_HOST=0.0.0.0

# Authentication
CLOUDOS_JWT_SECRET=change-me-in-production
CLOUDOS_TOKEN_TTL=24h

# Data Directory
CLOUDOS_DATA_DIR=/var/lib/cloudos

# Database (SQLite)
CLOUDOS_DATABASE_PATH=/var/lib/cloudos/cloudos.db

# Storage
CLOUDOS_STORAGE_PATH=/var/lib/cloudos/storage
